# Database
POSTGRES_USER=joryu
POSTGRES_PASSWORD=change_me
POSTGRES_DB=joryu
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://joryu:change_me@db:5432/joryu

# App
ENV=development
# true iken sadece landing + waitlist (mail toplama) açık; login/register kapalı.
# Uygulamayı yayına alırken false yap.
WAITLIST_ONLY=true
ADMIN_TOKEN=change_me_to_a_long_random_token
SECRET_KEY=change_me_to_a_long_random_secret

# Lemon Squeezy (Pro abonelik)
# Store dashboard > Settings > Webhooks: signing secret
LS_WEBHOOK_SECRET=
# Hosted checkout buy linkleri (Products > share > buy link)
LS_CHECKOUT_URL_MONTHLY=
LS_CHECKOUT_URL_YEARLY=

# PWA push bildirimi (Web Push / VAPID) — boşsa push devre dışı, e-posta yeterli
# Üretim: python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:aliilteriskeskin@gmail.com

# Hata izleme (Sentry) — boşsa devre dışı
SENTRY_DSN=

# E-posta (Resend) — boşsa mail gönderilmez, loglanır (dev)
RESEND_API_KEY=
MAIL_FROM=Joryu <noreply@joatolyesi.com>
# Şifre sıfırlama linklerinde kullanılan mutlak adres
BASE_URL=https://joatolyesi.com
